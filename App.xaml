<Application x:Class="BadmintonClub.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:BadmintonClub.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Petite charte graphique simple et cohérente -->
        <Color x:Key="AccentColor">#2E7D32</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush" Color="#1B5E20" />

        <conv:PhoneFormatConverter x:Key="PhoneFormat" />
        <conv:PhoneColorConverter x:Key="PhoneColor" />
        <conv:RunningBrushConverter x:Key="RunningBrush" />
        <conv:RunningTextConverter x:Key="RunningText" />
        <conv:RunningToggleTextConverter x:Key="RunningToggleText" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:MatchLevelBrushConverter x:Key="MatchLevelBrush" />
        <conv:MatchLevelTextConverter x:Key="MatchLevelText" />
        <conv:ActionBrushConverter x:Key="ActionBrush" />

        <!-- Case à cocher moderne (arrondie, verte cochée) -->
        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="19" Height="19" CornerRadius="5"
                                    BorderBrush="#B4BCB4" BorderThickness="1.6" Background="White"
                                    VerticalAlignment="Center">
                                <Grid>
                                    <Path x:Name="check" Data="M4.5,9.5 L8,13 L14,5.5"
                                          Stroke="White" StrokeThickness="2.2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round" Stretch="None" Visibility="Collapsed" />
                                    <Rectangle x:Name="dash" Width="9" Height="2.4" RadiusX="1" RadiusY="1"
                                               Fill="White" Visibility="Collapsed"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" Margin="7,0,0,0"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
                                <Setter TargetName="check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
                                <Setter TargetName="dash" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Background" Value="#F0F0F0" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <Grid>
                                <!-- Survol : assombrit sans écraser la couleur du bouton -->
                                <Border x:Name="hover" Background="Black" Opacity="0" CornerRadius="4" />
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="hover" Property="Opacity" Value="0.08" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="hover" Property="Opacity" Value="0.16" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,3" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#444444" />
        </Style>

        <!-- Bouton du menu latéral (RadioButton stylé, sélection animée) -->
        <Style x:Key="NavButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#D7EBD8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="48" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Hover" Background="#FFFFFF" Opacity="0" />
                            <Border x:Name="Highlight" Background="#2E7D32" Opacity="0" />
                            <Border x:Name="Accent" Width="4" HorizontalAlignment="Left"
                                    Background="#C8E6C9" Opacity="0" />
                            <ContentPresenter VerticalAlignment="Center" Margin="22,0,0,0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Hover" Property="Opacity" Value="0.06" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Highlight"
                                                Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="Accent"
                                                Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Highlight"
                                                Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="Accent"
                                                Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bouton discret pour actions par ligne (✏ / 🗑) -->
        <Style x:Key="RowButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
        </Style>

        <!-- Bouton danger (suppression) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E53935" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#C62828" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Boutons colorés compacts pour les lignes de tableau -->
        <Style x:Key="RowModifyButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2E7D32" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1B5E20" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="RowDeleteButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E53935" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#C62828" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Bouton bleu compact pour les lignes (gérer les libellés) -->
        <Style x:Key="RowBlueButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0D47A1" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- ===== DatePicker moderne (arrondi, focus vert, icône) ===== -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernCalendar" TargetType="Calendar">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DDDDDD" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CalendarStyle" Value="{StaticResource ModernCalendar}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="root" Background="White" BorderBrush="#CCCCCC"
                                BorderThickness="1" CornerRadius="8" Height="34">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0"
                                                   VerticalContentAlignment="Center" Margin="10,0,0,0"
                                                   BorderThickness="0" Background="Transparent" />
                                <Button x:Name="PART_Button" Grid.Column="1" Width="34"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="#2E7D32" Content="📅" FontSize="14" Focusable="False" />
                                <Grid x:Name="PART_DisabledVisual" Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup" AllowsTransparency="True"
                                       Placement="Bottom" StaysOpen="False" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="root" Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#233323" />
        </Style>

        <!-- Bouton « Excel » (vert Excel) -->
        <Style x:Key="ExcelButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#217346" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1B5E3A" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ===== Tableaux (DataGrid) ===== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8DED8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="AlternatingRowBackground" Value="#F5F8F5" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="HorizontalGridLinesBrush" Value="#ECECEC" />
            <Setter Property="VerticalGridLinesBrush" Value="#ECECEC" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="ColumnHeaderHeight" Value="36" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <!-- Perf : virtualisation lignes + colonnes en mode recyclage (conteneurs réutilisés
                 au lieu d'être recréés à chaque filtrage) → filtrage quasi instantané. -->
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True" />
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling" />
            <!-- Désélectionne la cellule quand on clique/focus hors du tableau. -->
            <EventSetter Event="LostKeyboardFocus" Handler="DataGrid_LostKeyboardFocus" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E8F0E8" />
            <Setter Property="Foreground" Value="#233323" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="BorderBrush" Value="#D2DED2" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAF4EA" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D6EAD6" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="8,0"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Cellule sélectionnée (mode copie) : surlignage vert net + bordure accent. -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#A5D6A7" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="Foreground" Value="#143C17" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Champ de recherche arrondi (utilisé dans les select2) -->
        <Style x:Key="RoundedSearchBox" TargetType="TextBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
