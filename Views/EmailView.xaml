<UserControl x:Class="BadmintonClub.Views.EmailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <TextBlock Text="E-mail" Style="{StaticResource PageTitle}" />
            <TextBlock Foreground="#777777" FontSize="12" Margin="0,2,0,0"
                       Text="Écrivez un message aux membres d'un ou plusieurs libellés." />
        </StackPanel>

        <StackPanel HorizontalAlignment="Left" MaxWidth="560" VerticalAlignment="Top">
            <TextBlock Text="Libellés destinataires" Style="{StaticResource FormLabel}" />
            <ctrl:MultiSelectComboBox x:Name="LabelSelect" />
            <TextBlock Text="Le message sera adressé à toutes les personnes associées à au moins un des libellés sélectionnés."
                       Foreground="#888888" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Content="🗂 Gérer les modèles" Click="Gerer_Click" />
            </StackPanel>

            <Button Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Left" Padding="16,9" Margin="0,16,0,0"
                    Click="Ecrire_Click">
                <StackPanel Orientation="Horizontal">
                    <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Width="16" Height="16"
                          Stretch="Uniform" Fill="White" VerticalAlignment="Center" />
                    <TextBlock Text="Écrire un mail" Margin="9,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <TextBlock x:Name="ResultText" Foreground="#2E7D32" FontSize="12" Margin="0,12,0,0"
                       TextWrapping="Wrap" />
        </StackPanel>
    </DockPanel>
</UserControl>
