<Window x:Class="BadmintonClub.Views.ManageLabelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Libellés du contact"
        Height="440" Width="420"
        WindowStartupLocation="CenterOwner"
        MinHeight="320" MinWidth="340"
        ShowInTaskbar="False">
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" x:Name="TitleText" Style="{StaticResource FormLabel}"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" Text="Cochez les libellés à associer au contact."
                   Foreground="#888888" FontSize="11" Margin="0,0,0,10" />

        <TextBlock DockPanel.Dock="Top" x:Name="LoadingText" Text="Chargement…"
                   Foreground="#999999" Margin="0,6,0,0" />

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Tout" Padding="8,4" MinWidth="0" Click="Tout_Click" />
                <Button Content="Aucun" Padding="8,4" MinWidth="0" Click="Aucun_Click" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
                <Button x:Name="ValiderButton" Content="✅ Valider"
                        Style="{StaticResource PrimaryButton}" Click="Valider_Click" Margin="0" />
            </StackPanel>
        </Grid>

        <ListBox x:Name="LabelsList" BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,4,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Text}" Margin="8,5"
                              IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
