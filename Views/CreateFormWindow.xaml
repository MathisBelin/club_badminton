<Window x:Class="BadmintonClub.Views.CreateFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Créer un Google Form" SizeToContent="Height" Width="470"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="24">
        <TextBlock Text="Créer un Google Form" FontSize="18" FontWeight="Bold"
                   Foreground="#233323" Margin="0,0,0,14" />

        <TextBlock Text="Nom du formulaire" Style="{StaticResource FormLabel}" />
        <TextBox x:Name="FormNameBox" Margin="0,0,0,14" />

        <RadioButton x:Name="RadioBlank" GroupName="Type" Content="Formulaire vierge"
                     IsChecked="True" Checked="Type_Checked" Margin="0,0,0,6" />
        <RadioButton x:Name="RadioModel" GroupName="Type" Content="À partir d'un modèle"
                     Checked="Type_Checked" Margin="0,0,0,6" />

        <StackPanel x:Name="TemplateZone" Visibility="Collapsed" Margin="24,4,0,0">
            <RadioButton x:Name="RadioFromList" GroupName="Source" Content="Depuis la liste"
                         IsChecked="True" Checked="Source_Checked" Margin="0,0,0,6" />

            <StackPanel x:Name="ListZone" Margin="20,0,0,8">
                <ComboBox x:Name="ModelCombo" DisplayMemberPath="Name" />
                <TextBlock x:Name="NoModelHint" Foreground="#C62828" FontSize="12" Margin="0,6,0,0"
                           Text="Aucun modèle enregistré. Ouvrez ⚙ Configuration d'un formulaire puis « ⭐ Enregistrer comme modèle »."
                           Visibility="Collapsed" TextWrapping="Wrap" />
            </StackPanel>

            <RadioButton x:Name="RadioFromFile" GroupName="Source" Content="Importer un fichier"
                         Checked="Source_Checked" Margin="0,6,0,6" />

            <StackPanel x:Name="ImportZone" Margin="20,0,0,0" Visibility="Collapsed">
                <Border x:Name="DropZone" AllowDrop="True" Drop="DropZone_Drop" DragOver="DropZone_DragOver"
                        Background="#F4F8FB" BorderBrush="#B7D3EA" BorderThickness="1.5" CornerRadius="8"
                        Padding="16" MinHeight="70" Cursor="Hand" MouseLeftButtonUp="Browse_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="DropText" Text="Glissez un fichier .json ici, ou cliquez pour parcourir"
                                   Foreground="#4A6072" TextAlignment="Center" TextWrapping="Wrap" />
                        <TextBlock x:Name="SelectedFileText" Foreground="#233323" FontWeight="SemiBold"
                                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Visibility="Collapsed" />
                    </StackPanel>
                </Border>
                <Button Content="📂 Parcourir…" HorizontalAlignment="Left" Margin="0,8,0,0"
                        Click="Browse_Click" Padding="12,6" />
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Annuler" Click="Annuler_Click" Padding="14,7" />
            <Button Content="➕ Créer" Click="Creer_Click" Style="{StaticResource PrimaryButton}"
                    Padding="14,7" Margin="8,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
