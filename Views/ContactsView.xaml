<UserControl x:Class="BadmintonClub.Views.ContactsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <!-- En-tête -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Contacts" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0" />

            <!-- Barre d'outils : actions à droite -->
            <DockPanel Margin="0,12,0,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📥 Importer" Click="Importer_Click"
                            ToolTip="Importer des contacts (fichier Excel/CSV ou liste d'e-mails)" />
                    <Button Content="📊 Exporter CSV" Style="{StaticResource ExcelButton}"
                            Click="Exporter_Click"
                            ToolTip="Exporter les contacts en CSV (tous, ou la sélection)" />
                    <Button Content="➕ Ajouter" Style="{StaticResource PrimaryButton}"
                            Click="Ajouter_Click" Margin="0" />
                </StackPanel>
            </DockPanel>

            <!-- Filtres : recherche + filtre par libellé, sur une ligne compacte -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" VerticalAlignment="Center">
                <ctrl:SearchBox x:Name="SearchBox" Width="230" Margin="0,0,16,0"
                                TextChanged="SearchBox_TextChanged" />
                <TextBlock Text="Libellé :" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="#555555" />
                <ctrl:MultiSelectComboBox x:Name="LabelFilter" Width="220" VerticalAlignment="Center" />
                <Button x:Name="ClearLabelBtn" Content="✕" Visibility="Collapsed" MinWidth="0"
                        Padding="9,5" Margin="6,0,0,0" Click="ResetFilter_Click"
                        ToolTip="Effacer le filtre par libellé" />
                <CheckBox x:Name="HideIncompleteCheck" VerticalAlignment="Center" Margin="20,0,0,0"
                          Content="Masquer les contacts sans nom / prénom / tél"
                          Checked="HideIncomplete_Changed" Unchecked="HideIncomplete_Changed"
                          ToolTip="Cache les contacts qui n'ont qu'une adresse e-mail" />
                <Button x:Name="AdvancedToggle" Content="🔎 Recherche avancée" Margin="20,0,0,0"
                        VerticalAlignment="Center" Click="AdvancedToggle_Click"
                        ToolTip="Filtres avancés (période d'ajout, doublons)" />
            </StackPanel>
        </StackPanel>

        <!-- Recherche avancée -->
        <Border x:Name="AdvancedPanel" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#F4F8FB" BorderBrush="#D6E4F0" BorderThickness="1"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Ajouté entre :" VerticalAlignment="Center" Foreground="#555555"
                           FontWeight="SemiBold" Margin="0,0,8,0" />
                <DatePicker x:Name="FromDate" Width="160" SelectedDateChanged="DateFilter_Changed" />
                <TextBlock Text="et" VerticalAlignment="Center" Margin="8,0,8,0" Foreground="#555555" />
                <DatePicker x:Name="ToDate" Width="160" SelectedDateChanged="DateFilter_Changed" />
                <Button x:Name="ClearDatesBtn" Content="✕" MinWidth="0" Padding="9,5" Margin="6,0,0,0"
                        VerticalAlignment="Center" Click="ClearDates_Click" ToolTip="Effacer la période" />
                <ToggleButton x:Name="DuplicatesToggle" Content="🔁 Doublons" Margin="28,0,0,0"
                              VerticalAlignment="Center" Padding="10,5"
                              Checked="Duplicates_Changed" Unchecked="Duplicates_Changed"
                              ToolTip="N'afficher que les personnes ayant un homonyme (même nom et prénom)" />
            </StackPanel>
        </Border>

        <!-- Barre d'actions groupées (animée) -->
        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#B71C1C" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkDeleteButton" Style="{StaticResource DangerButton}"
                            Click="BulkDelete_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Barre de pagination -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Lignes par page :" VerticalAlignment="Center"
                           Foreground="#555555" Margin="0,0,8,0" />
                <ComboBox x:Name="PageSizeCombo" Width="70" SelectionChanged="PageSize_Changed"
                          VerticalContentAlignment="Center">
                    <ComboBoxItem IsSelected="True">20</ComboBoxItem>
                    <ComboBoxItem>50</ComboBoxItem>
                    <ComboBoxItem>100</ComboBoxItem>
                </ComboBox>
                <Button x:Name="PrevBtn" Content="◀ Précédent" Click="PrevPage_Click" Margin="16,0,0,0" />
                <TextBlock x:Name="PageInfo" VerticalAlignment="Center" Foreground="#555555"
                           Margin="10,0,10,0" MinWidth="90" TextAlignment="Center" />
                <Button x:Name="NextBtn" Content="Suivant ▶" Click="NextPage_Click" Margin="0" />
            </StackPanel>
        </Border>

        <!-- Tableau -->
        <Grid>
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader"
                  Sorting="Grid_Sorting"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" SortDirection="Ascending" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                <DataGridTemplateColumn Header="Téléphone" Width="150" SortMemberPath="Telephone"
                                        ClipboardContentBinding="{Binding Telephone, Converter={StaticResource PhoneFormat}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Telephone, Converter={StaticResource PhoneFormat}}"
                                       Foreground="{Binding Telephone, Converter={StaticResource PhoneColor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="E-mail" Width="2*" SortMemberPath="Email"
                                        ClipboardContentBinding="{Binding Email}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                <Hyperlink Click="Email_Click" Foreground="#1565C0"
                                           ToolTip="Écrire un e-mail via Gmail">
                                    <Run Text="{Binding Email}" />
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Ajouté le" Width="110" SortMemberPath="DateInscription"
                                    Binding="{Binding DateInscription, StringFormat=\{0:dd/MM/yyyy\}}" />
                <DataGridTemplateColumn Header="Actions" Width="300" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource RowModifyButton}" Content="✏ Modifier"
                                        Click="Modifier_Click" />
                                <Button Style="{StaticResource RowBlueButton}" Content="🏷 Libellés"
                                        ToolTip="Gérer les libellés" Click="PlusOptions_Click" />
                                <Button Style="{StaticResource RowDeleteButton}" Content="🗑 Supprimer"
                                        Click="Supprimer_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0" Foreground="#999999" FontSize="13" />
        </Grid>
    </DockPanel>
</UserControl>
