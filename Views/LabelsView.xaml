<UserControl x:Class="BadmintonClub.Views.LabelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">

        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Libellés Gmail" Style="{StaticResource PageTitle}" />
                <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="➕ Créer un libellé" Style="{StaticResource PrimaryButton}"
                        Click="Creer_Click" Margin="0" />
            </StackPanel>
        </Grid>

        <!-- Barre d'actions groupées -->
        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#B71C1C" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkDeleteButton" Style="{StaticResource DangerButton}"
                            Click="BulkDelete_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Libellé" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Membres" Binding="{Binding NombreMembres}" Width="100" />
                <DataGridTemplateColumn Header="Actions" Width="300" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource RowBlueButton}" Content="👁 Voir"
                                        ToolTip="Voir les membres" Click="Voir_Click" />
                                <Button Style="{StaticResource RowModifyButton}" Content="✏ Renommer"
                                        Click="Renommer_Click" />
                                <Button Style="{StaticResource RowDeleteButton}" Content="🗑 Supprimer"
                                        Click="Supprimer_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0" Foreground="#999999" FontSize="13" />
        </Grid>
    </DockPanel>
</UserControl>
