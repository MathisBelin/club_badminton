<UserControl x:Class="BadmintonClub.Views.AutoSyncView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Synchronisation automatique" Style="{StaticResource PageTitle}" />
                <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
            <ctrl:SearchBox Grid.Column="1" x:Name="SearchBox" Width="220" Margin="0,0,12,0"
                            VerticalAlignment="Center" PlaceholderText="Rechercher par nom…"
                            TextChanged="Search_Changed" />
            <Button Grid.Column="2" Content="➕ Ajouter" Style="{StaticResource PrimaryButton}"
                    Click="Ajouter_Click" Margin="0" VerticalAlignment="Center" />
        </Grid>

        <Grid>
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                      SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader"
                      MouseDoubleClick="Grid_MouseDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <!-- Brouillon (champs incomplets) : non lançable → ligne orange. -->
                            <DataTrigger Binding="{Binding IsComplete}" Value="False">
                                <Setter Property="Background" Value="#FFE0B2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Libellé cible" Binding="{Binding LabelName}" Width="*" />
                    <DataGridTemplateColumn Header="Lien" Width="1.6*"
                                            ClipboardContentBinding="{Binding SheetUrl}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                    <Hyperlink Click="OpenLink_Click" Foreground="#1565C0" ToolTip="Ouvrir le Sheet">
                                        <Run Text="{Binding SheetUrl}" />
                                    </Hyperlink>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="État" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="●" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                               Foreground="{Binding IsRunning, Converter={StaticResource RunningBrush}}" />
                                    <TextBlock VerticalAlignment="Center" FontSize="12"
                                               Foreground="{Binding IsRunning, Converter={StaticResource RunningBrush}}"
                                               Text="{Binding IsRunning, Converter={StaticResource RunningText}}" />
                                    <TextBlock Text="⟳" FontSize="13" Foreground="#2E7D32" Margin="6,0,0,0"
                                               VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5"
                                               Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock.RenderTransform>
                                            <RotateTransform Angle="0" />
                                        </TextBlock.RenderTransform>
                                        <TextBlock.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                            From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </TextBlock.Triggers>
                                    </TextBlock>
                                    <TextBlock Text="{Binding ProgressText}" FontSize="12" Foreground="#2E7D32"
                                               VerticalAlignment="Center" Margin="4,0,0,0"
                                               Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Minuteur" Binding="{Binding CountdownText}" Width="90" />
                    <DataGridTemplateColumn Header="Suivi" Width="110" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="📋" FontSize="14"
                                            Click="Trace_Click" ToolTip="Voir les personnes associées par cette synchro"
                                            Background="#1565C0" Foreground="White" BorderBrush="#0D47A1"
                                            MinWidth="0" Padding="9,4" Margin="2,0"
                                            Visibility="{Binding HasTrace, Converter={StaticResource BoolToVisibility}}" />
                                    <Button Content="⚠" FontSize="15"
                                            Click="Warning_Click" ToolTip="{Binding WarningTooltip}"
                                            Background="#F9A825" Foreground="White" BorderBrush="#F57F17"
                                            MinWidth="0" Padding="9,4" Margin="2,0"
                                            Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Actions" Width="280" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="{Binding IsRunning, Converter={StaticResource RunningToggleText}}"
                                            Style="{StaticResource RowBlueButton}" Click="Toggle_Click"
                                            ToolTip="Démarrer / arrêter" />
                                    <Button Style="{StaticResource RowModifyButton}" Content="✏ Modifier"
                                            Click="Edit_Click" />
                                    <Button Style="{StaticResource RowDeleteButton}" Content="🗑 Supprimer"
                                            Click="Delete_Click" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,40,0,0" Foreground="#999999" FontSize="13"
                       Text="Aucune synchronisation. Cliquez sur « ➕ Ajouter »." />
        </Grid>
    </DockPanel>
</UserControl>
