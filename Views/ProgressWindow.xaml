<Window x:Class="BadmintonClub.Views.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner" Width="380" SizeToContent="Height">
    <Border Background="White" CornerRadius="8" Padding="22" BorderBrush="#DDDDDD" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#40000000" BlurRadius="16" ShadowDepth="3" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                       Foreground="#233323" Margin="0,0,0,12" />
            <ProgressBar x:Name="Bar" Height="20" Minimum="0" Foreground="#2E7D32" />
            <TextBlock x:Name="StatusText" Margin="0,10,0,0" Foreground="#555555" HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
