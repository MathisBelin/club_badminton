<Window x:Class="BadmintonClub.Views.FormConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration du formulaire" Width="660" Height="660"
        WindowStartupLocation="CenterOwner" Background="#F4F6F4" MinWidth="560" MinHeight="440">
    <DockPanel Margin="18">

        <Border DockPanel.Dock="Bottom" Background="White" BorderBrush="#E4E9E4" BorderThickness="1"
                CornerRadius="8" Padding="12,10" Margin="0,12,0,0">
            <Grid>
                <Button Content="⭐ Enregistrer comme modèle" HorizontalAlignment="Left"
                        Click="SaveAsModel_Click" Padding="14,7"
                        ToolTip="Enregistrer la structure de ce formulaire comme modèle réutilisable (local)" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Annuler" Click="Annuler_Click" Padding="14,7" />
                    <Button Content="💾 Enregistrer" Style="{StaticResource PrimaryButton}"
                            Click="Enregistrer_Click" Padding="14,7" Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" BorderBrush="#E4E9E4" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Nom du formulaire" Style="{StaticResource FormLabel}" />
                        <TextBox x:Name="NameBox" Margin="0,0,0,12" />

                        <TextBlock Text="Libellé associé (un seul)" Style="{StaticResource FormLabel}" />
                        <ComboBox x:Name="LabelCombo" DisplayMemberPath="Nom" SelectedValuePath="ResourceName"
                                  Width="280" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E4E9E4" BorderThickness="1"
                        CornerRadius="8" Padding="16" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Correspondance des réponses (colonnes du contact)"
                                   FontWeight="SemiBold" Foreground="#233323" FontSize="14" Margin="0,0,0,6" />
                        <TextBlock Foreground="#777777" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"
                                   Text="Associez une question texte du formulaire à chaque colonne du contact. Choisissez « (aucune correspondance) » pour ne pas renseigner la colonne." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Prénom" VerticalAlignment="Center"
                                       Foreground="#444444" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="MapPrenom" Margin="0,0,0,8"
                                      DisplayMemberPath="Title" SelectedValuePath="QuestionId" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Nom" VerticalAlignment="Center"
                                       Foreground="#444444" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="MapNom" Margin="0,0,0,8"
                                      DisplayMemberPath="Title" SelectedValuePath="QuestionId" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Téléphone" VerticalAlignment="Center"
                                       Foreground="#444444" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="2" Grid.Column="1" x:Name="MapTel" Margin="0,0,0,8"
                                      DisplayMemberPath="Title" SelectedValuePath="QuestionId" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="E-mail" VerticalAlignment="Center"
                                       Foreground="#444444" Margin="0,0,0,8" />
                            <ComboBox Grid.Row="3" Grid.Column="1" x:Name="MapEmail" Margin="0,0,0,8"
                                      DisplayMemberPath="Title" SelectedValuePath="QuestionId" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Mails secondaires" VerticalAlignment="Center"
                                       Foreground="#444444" />
                            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="MapSecondaryEmails"
                                      DisplayMemberPath="Title" SelectedValuePath="QuestionId" />
                        </Grid>
                    </StackPanel>
                </Border>

                <TextBlock Text="Paramétrage des réponses (questions à choix unique)"
                           FontWeight="SemiBold" Foreground="#233323" FontSize="14" Margin="2,0,0,8" />
                <TextBlock Foreground="#777777" FontSize="12" Margin="2,0,0,8" TextWrapping="Wrap"
                           Text="Pour chaque réponse d'une question à choix unique, vous pouvez déclencher : « Ajouter à la liste d'attente » ou « Annuler l'inscription » (appliqué à la validation des réponses)." />

                <ItemsControl x:Name="QuestionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" BorderBrush="#E4E9E4" BorderThickness="1"
                                    CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#202124"
                                               TextWrapping="Wrap" Margin="0,0,0,6" />
                                    <!-- Question à choix unique : options paramétrables -->
                                    <ItemsControl ItemsSource="{Binding Options}"
                                                  Visibility="{Binding IsSingleChoice, Converter={StaticResource BoolToVisibility}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3,0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="◯" Foreground="#9AA0A6" Margin="0,0,8,0" />
                                                        <TextBlock Text="{Binding OptionValue}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <ComboBox Grid.Column="1" Width="240" VerticalAlignment="Center"
                                                              ItemsSource="{Binding Rules, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              DisplayMemberPath="Label" SelectedValuePath="Value"
                                                              SelectedValue="{Binding Rule, Mode=TwoWay}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="(type non paramétrable)" Foreground="#9AA0A6" FontSize="12"
                                               Visibility="{Binding IsOther, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="EmptyHint" Foreground="#999999" FontSize="12" Margin="2,4,0,0"
                           Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
