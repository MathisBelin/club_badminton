<Window x:Class="BadmintonClub.Views.ComposeChoiceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BadmintonClub.Controls"
        Title="Écrire un mail"
        Height="240" Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Comment souhaitez-vous rédiger ce mail ?"
                   Style="{StaticResource FormLabel}" Margin="0,0,0,10" />

        <RadioButton Grid.Row="1" x:Name="RadioBlank" Content="Mail vierge" IsChecked="True"
                     GroupName="Mode" Margin="0,0,0,6" Checked="Mode_Checked" />
        <RadioButton Grid.Row="2" x:Name="RadioModel" Content="À partir d'un modèle enregistré"
                     GroupName="Mode" Checked="Mode_Checked" />

        <StackPanel x:Name="TemplatePanel" Grid.Row="3" Orientation="Horizontal"
                    Margin="24,10,0,0" VerticalAlignment="Top" Visibility="Collapsed">
            <ctrl:MultiSelectComboBox x:Name="TemplateSelect" SingleSelect="True" Width="300" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button Content="✅ Continuer" Style="{StaticResource PrimaryButton}"
                    Click="Continuer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
