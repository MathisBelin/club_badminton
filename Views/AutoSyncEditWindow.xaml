<Window x:Class="BadmintonClub.Views.AutoSyncEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BadmintonClub.Controls"
        Title="Synchronisation automatique"
        Height="640" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Nom de la synchro" Style="{StaticResource FormLabel}" />
                <TextBox x:Name="NameBox" />

                <TextBlock Text="Lien du Google Sheet" Style="{StaticResource FormLabel}" Margin="0,12,0,0" />
                <TextBox x:Name="UrlBox" />

                <TextBlock Text="Libellé cible" Style="{StaticResource FormLabel}" Margin="0,12,0,0" />
                <ctrl:MultiSelectComboBox x:Name="LabelSelect" SingleSelect="True" HorizontalAlignment="Left" Width="320" />
                <TextBlock Text="Un libellé ne peut être ciblé que par une seule synchro."
                           Foreground="#888888" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap" />

                <Border Background="#F4F8F4" BorderBrush="#DDE7DD" BorderThickness="1"
                        CornerRadius="6" Padding="14" Margin="0,14,0,0">
                    <StackPanel>
                        <TextBlock Text="Lignes lues" Style="{StaticResource FormLabel}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="De la ligne" VerticalAlignment="Center" Foreground="#555555" />
                            <TextBox x:Name="StartRowBox" Width="52" MaxLength="6" Margin="6,0,6,0"
                                     HorizontalContentAlignment="Center" />
                            <TextBlock Text="à la ligne" VerticalAlignment="Center" Foreground="#555555" />
                            <TextBox x:Name="EndRowBox" Width="52" MaxLength="6" Margin="6,0,6,0"
                                     HorizontalContentAlignment="Center" ToolTip="Laisser vide = jusqu'au bas" />
                            <TextBlock Text="(fin vide = jusqu'au bas)" VerticalAlignment="Center"
                                       Foreground="#888888" FontSize="11" />
                        </StackPanel>

                        <TextBlock Text="Colonnes de chaque champ (lettre)" Style="{StaticResource FormLabel}" Margin="0,12,0,0" />
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                <TextBlock Text="Nom" FontSize="11" Foreground="#555555" />
                                <TextBox x:Name="ColNomBox" Width="44" MaxLength="2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock Text="Prénom" FontSize="11" Foreground="#555555" />
                                <TextBox x:Name="ColPrenomBox" Width="44" MaxLength="2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,14,0">
                                <TextBlock Text="Téléphone" FontSize="11" Foreground="#555555" />
                                <TextBox x:Name="ColTelBox" Width="44" MaxLength="2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="E-mail" FontSize="11" Foreground="#555555" />
                                <TextBox x:Name="ColEmailBox" Width="44" MaxLength="2" HorizontalContentAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="AutoFillBtn" Content="✨ Remplissage automatique"
                                    Click="AutoFill_Click"
                                    ToolTip="Détecter les colonnes d'après les en-têtes du Sheet" />
                            <Button x:Name="TestBtn" Content="🔍 Tester" Margin="8,0,0,0" Click="Test_Click"
                                    ToolTip="Lire les lignes avec les colonnes indiquées" />
                        </StackPanel>

                        <Border x:Name="TestBorder" Visibility="Collapsed" Margin="0,10,0,0"
                                Background="White" BorderBrush="#DDE7DD" BorderThickness="1" CornerRadius="4" Padding="10,8">
                            <TextBlock x:Name="TestResult" FontSize="12" Foreground="#333333" TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <CheckBox x:Name="EnabledCheck" Margin="0,14,0,0"
                          Content="Activer cette synchro (toutes les 5 minutes)" IsChecked="True" />
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button Content="💾 Enregistrer" Style="{StaticResource PrimaryButton}"
                    Click="Enregistrer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
