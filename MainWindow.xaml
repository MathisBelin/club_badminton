<Window x:Class="BadmintonClub.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Club de Badminton"
        Icon="assets/app.ico"
        Height="640" Width="1000"
        WindowStartupLocation="CenterScreen"
        MinHeight="480" MinWidth="820">
    <Grid>

        <!-- ============ Application (visible une fois connecté) ============ -->
        <Grid x:Name="AppRoot" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Menu latéral fixe -->
            <Border Grid.Column="0" Background="#1B5E20">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="22,24,22,28">
                        <TextBlock Text="🏸" FontSize="30" />
                        <TextBlock Text="Club Badminton" Foreground="White" FontSize="18"
                                   FontWeight="Bold" Margin="0,4,0,0" />
                        <TextBlock Text="Gestion du club" Foreground="#A5D6A7" FontSize="12" />
                    </StackPanel>

                    <StackPanel x:Name="NavPanel" DockPanel.Dock="Top">
                        <RadioButton x:Name="NavContacts" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="contacts" Content="👥   Contacts"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavLabels" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="labels" Content="🏷   Libellés Gmail"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavAssociation" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="association" Content="🔗   Association"
                                     Checked="Nav_Checked" />
                        <!-- Accessible uniquement via le bouton « Inscriptions non finalisées » de la page Association. -->
                        <RadioButton x:Name="NavPending" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="pending" Visibility="Collapsed"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavEmail" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="email" Checked="Nav_Checked">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" Width="17" Height="17"
                                      Stretch="Uniform" VerticalAlignment="Center"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" />
                                <TextBlock Text="E-mail" Margin="14,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </RadioButton>
                        <RadioButton x:Name="NavSheets" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="sheets" Content="📄   Google Sheets"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavAutoSync" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="autosync" Content="🔄   Synchro auto"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavHistory" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="history" Content="🕓   Historique"
                                     Checked="Nav_Checked" />
                        <RadioButton x:Name="NavSettings" Style="{StaticResource NavButton}"
                                     GroupName="Nav" Tag="settings" Content="⚙   Paramètres"
                                     Checked="Nav_Checked" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                        <Border Margin="14,0,14,6" Background="#124C1B" CornerRadius="8" Padding="12">
                            <StackPanel>
                                <TextBlock Text="👤 Compte Google" Foreground="#A5D6A7" FontSize="10" />
                                <TextBlock x:Name="AccountEmailText" Text="Non connecté" Foreground="White"
                                           FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,3,0,8" />
                                <Button x:Name="LogoutButton" Content="🔓 Se déconnecter"
                                        Click="Deconnexion_Click" Margin="0" HorizontalAlignment="Stretch"
                                        Padding="8,6" ToolTip="Se déconnecter (pour changer de compte)" />
                            </StackPanel>
                        </Border>
                        <TextBlock x:Name="VersionText" Foreground="#A5D6A7" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,0,0,10" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Zone de contenu -->
            <Border Grid.Column="1" Background="#F4F6F4">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E4E9E4"
                            BorderThickness="0,0,0,1" Padding="24,10">
                        <Grid>
                            <TextBlock Text="🏸 Gestion du club de badminton" FontWeight="SemiBold"
                                       Foreground="#233323" VerticalAlignment="Center" />

                            <Border x:Name="OfflineWarning" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                                    CornerRadius="14" Padding="12,4" Visibility="Collapsed">
                                <TextBlock Text="⚠ Pas de connexion Internet — synchronisation en pause"
                                           Foreground="#B71C1C" FontSize="12" FontWeight="SemiBold" />
                            </Border>

                            <!-- Boutons synchro : synchro instantanée + notifications -->
                            <StackPanel x:Name="NotifArea" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <Button x:Name="NotifButton" Click="NotifButton_Click" Padding="8,4"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        ToolTip="Synchronisations">
                                    <Grid>
                                        <TextBlock Text="🔄" FontSize="17" />
                                        <Border x:Name="NotifBadge" Background="#2E7D32" CornerRadius="8"
                                                MinWidth="16" Height="16" Padding="3,0" Visibility="Collapsed"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-6,0">
                                            <TextBlock x:Name="NotifCount" Foreground="White" FontSize="10"
                                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border x:Name="NotifWarnBadge" Background="#F9A825" CornerRadius="8"
                                                Width="16" Height="16" Visibility="Collapsed"
                                                HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,-4,0,0"
                                                ToolTip="Des synchros ont des inscriptions non finalisées">
                                            <TextBlock Text="⚠" Foreground="White" FontSize="9"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Button>
                                <Popup x:Name="NotifPopup" StaysOpen="False" Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=NotifButton}"
                                       AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="-220">
                                    <Border Background="White" BorderBrush="#DDE7DD" BorderThickness="1"
                                            CornerRadius="6" Padding="12" Width="320" Margin="0,4,8,0">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#40000000" BlurRadius="12" ShadowDepth="2" />
                                        </Border.Effect>
                                        <StackPanel>
                                            <TextBlock Text="Synchronisations" FontWeight="SemiBold"
                                                       Foreground="#233323" Margin="0,0,0,8" />
                                            <TextBlock x:Name="NotifEmpty" Text="Aucune synchro en marche."
                                                       Foreground="#999999" FontSize="12" Visibility="Collapsed" />
                                            <ItemsControl x:Name="NotifList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="0,4" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                                            <StackPanel>
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0">
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="⚠" FontSize="12" Foreground="#F9A825"
                                                                                       VerticalAlignment="Center" Margin="0,0,4,0"
                                                                                       Visibility="{Binding HasIncomplete, Converter={StaticResource BoolToVisibility}}" />
                                                                            <TextBlock Text="{Binding Name}" FontSize="13"
                                                                                       TextTrimming="CharacterEllipsis" />
                                                                        </StackPanel>
                                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                            <TextBlock Text="⟳" FontSize="12" Foreground="#2E7D32"
                                                                                       Margin="0,0,5,0" VerticalAlignment="Center"
                                                                                       RenderTransformOrigin="0.5,0.5">
                                                                                <TextBlock.RenderTransform>
                                                                                    <RotateTransform Angle="0" />
                                                                                </TextBlock.RenderTransform>
                                                                                <TextBlock.Triggers>
                                                                                    <EventTrigger RoutedEvent="Loaded">
                                                                                        <BeginStoryboard>
                                                                                            <Storyboard>
                                                                                                <DoubleAnimation
                                                                                                    Storyboard.TargetProperty="(TextBlock.RenderTransform).(RotateTransform.Angle)"
                                                                                                    From="0" To="360" Duration="0:0:1.1" RepeatBehavior="Forever" />
                                                                                            </Storyboard>
                                                                                        </BeginStoryboard>
                                                                                    </EventTrigger>
                                                                                </TextBlock.Triggers>
                                                                            </TextBlock>
                                                                            <TextBlock Text="{Binding CountdownText}" FontSize="11"
                                                                                       Foreground="#2E7D32" VerticalAlignment="Center" />
                                                                            <TextBlock Text="{Binding ProgressText}" FontSize="11" FontWeight="SemiBold"
                                                                                       Foreground="#2E7D32" VerticalAlignment="Center" Margin="6,0,0,0"
                                                                                       Visibility="{Binding IsImporting, Converter={StaticResource BoolToVisibility}}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <Button Content="⟳" FontSize="15" Foreground="#2E7D32"
                                                                                Click="SyncOne_Click" ToolTip="Synchroniser maintenant"
                                                                                MinWidth="0" Padding="6,2" Margin="0,0,2,0"
                                                                                Background="Transparent" BorderThickness="0" Cursor="Hand" />
                                                                        <Button Content="⏸" FontSize="13"
                                                                                Click="Suspend_Click" ToolTip="Suspendre"
                                                                                MinWidth="0" Padding="6,2"
                                                                                Background="Transparent" BorderThickness="0" Cursor="Hand" />
                                                                    </StackPanel>
                                                                </Grid>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Visibility="{Binding HasIncomplete, Converter={StaticResource BoolToVisibility}}">
                                                                    <Hyperlink Click="NotifPending_Click" Foreground="#B8860B">
                                                                        <Run Text="⏳ Voir les inscriptions non finalisées" />
                                                                    </Hyperlink>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ContentControl x:Name="ContentHost" />
                </DockPanel>
            </Border>
        </Grid>

        <!-- ============ Écran de connexion ============ -->
        <Grid x:Name="LoginRoot" Background="#1B5E20">
            <Border Background="White" CornerRadius="12" Padding="40,36" Width="420"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="🏸" FontSize="46" HorizontalAlignment="Center" />
                    <TextBlock Text="Club de Badminton" FontSize="22" FontWeight="Bold"
                               Foreground="#233323" HorizontalAlignment="Center" Margin="0,8,0,2" />
                    <TextBlock Text="Connectez-vous avec votre compte Google pour accéder à la gestion du club."
                               Foreground="#777777" TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,24" />
                    <Button x:Name="ConnexionButton" Content="Se connecter avec Google"
                            Style="{StaticResource PrimaryButton}" Padding="16,10"
                            HorizontalAlignment="Center" Click="Connexion_Click" />
                    <Button x:Name="CancelLoginButton" Content="Annuler la connexion"
                            Padding="14,8" HorizontalAlignment="Center" Margin="0,10,0,0"
                            Visibility="Collapsed" Click="AnnulerConnexion_Click" />
                    <TextBlock x:Name="LoginStatus" Foreground="#B71C1C" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,16,0,0" />
                    <TextBlock x:Name="LoginVersionText" Foreground="#AAAAAA" FontSize="10"
                               HorizontalAlignment="Center" Margin="0,18,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
