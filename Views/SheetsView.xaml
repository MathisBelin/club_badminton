<UserControl x:Class="BadmintonClub.Views.SheetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="24">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Google Sheets" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0" />

            <DockPanel Margin="0,12,0,0">
                <Button DockPanel.Dock="Right" Content="➕ Créer un Sheet"
                        Style="{StaticResource PrimaryButton}" Click="Creer_Click" Margin="0" />
                <WrapPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                        <TextBlock Text="🔎" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" />
                        <TextBox x:Name="SearchBox" Width="200" TextChanged="Search_Changed"
                                 ToolTip="Rechercher par nom" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Du" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555555" />
                        <DatePicker x:Name="FromDate" Width="130" SelectedDateChanged="Date_Changed" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,8,4">
                        <TextBlock Text="Au" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555555" />
                        <DatePicker x:Name="ToDate" Width="130" SelectedDateChanged="Date_Changed" />
                    </StackPanel>
                    <Button Content="Réinitialiser" Margin="0,0,0,4" Click="ResetFilter_Click" />
                </WrapPanel>
            </DockPanel>
        </StackPanel>

        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#B71C1C" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkDeleteButton" Style="{StaticResource DangerButton}"
                            Click="BulkDelete_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Créé le"
                                    Binding="{Binding DateCreation, StringFormat=\{0:dd/MM/yyyy HH:mm\}}"
                                    Width="140" />
                <DataGridTextColumn Header="Lien" Binding="{Binding Url}" Width="2*" />
                <DataGridTemplateColumn Header="Actions" Width="180" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource RowButton}" Content="🔗"
                                        ToolTip="Ouvrir le lien" Click="Ouvrir_Click" />
                                <Button Style="{StaticResource RowButton}" Content="📋"
                                        ToolTip="Copier le lien" Click="Copier_Click" />
                                <Button Style="{StaticResource RowButton}" Content="⚙"
                                        ToolTip="Options (partage, CSV)" Click="Options_Click" />
                                <Button Style="{StaticResource RowButton}" Content="🗑"
                                        ToolTip="Supprimer" Click="Supprimer_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
