<UserControl x:Class="BadmintonClub.Views.PendingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Personnes en attente" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0"
                       Text="Personnes ayant renseigné des infos dans le Sheet mais sans e-mail." />

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                <TextBlock Text="Libellé :" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#555555" FontWeight="SemiBold" />
                <ctrl:MultiSelectComboBox x:Name="LabelFilter" Width="240" VerticalAlignment="Center" />
                <Button x:Name="ClearFilterBtn" Content="✕" Visibility="Collapsed" MinWidth="0"
                        Padding="9,5" Margin="6,0,0,0" Click="ClearFilter_Click"
                        ToolTip="Effacer le filtre par libellé" />
            </StackPanel>
        </StackPanel>

        <Grid>
            <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                      SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Libellé" Binding="{Binding LabelName}" Width="*" />
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,40,0,0" Foreground="#999999" FontSize="13" />
        </Grid>
    </DockPanel>
</UserControl>
