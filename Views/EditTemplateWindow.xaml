<Window x:Class="BadmintonClub.Views.EditTemplateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modèle de mail"
        Height="560" Width="560"
        WindowStartupLocation="CenterOwner"
        MinHeight="460" MinWidth="440"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="76" AllowDrop="True" DragOver="Drop_DragOver" Drop="Drop_Drop"
                MouseLeftButtonUp="Drop_Click" Cursor="Hand" Margin="0,0,0,12">
            <Grid>
                <Rectangle x:Name="DropRect" Stroke="#9CB89C" StrokeDashArray="4 3" StrokeThickness="2"
                           RadiusX="10" RadiusY="10" Fill="#F7FAF7" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DropIcon" Text="✉" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <TextBlock x:Name="DropHint" Foreground="#555555" TextAlignment="Center"
                               Text="Glissez un e-mail (.eml) ici pour pré-remplir,&#x0a;ou cliquez pour le choisir." />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Nom du modèle" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="NameBox" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Objet" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="SubjectBox" />
        </StackPanel>

        <TextBlock Grid.Row="3" Text="Message" Style="{StaticResource FormLabel}" />
        <TextBox Grid.Row="4" x:Name="BodyBox" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto" Padding="6" VerticalContentAlignment="Top"
                 MinHeight="120" />

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button Content="💾 Enregistrer" Style="{StaticResource PrimaryButton}"
                    Click="Enregistrer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
