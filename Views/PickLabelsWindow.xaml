<Window x:Class="BadmintonClub.Views.PickLabelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BadmintonClub.Controls"
        Title="Libellés"
        Height="280" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" x:Name="TitleText" Style="{StaticResource FormLabel}"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock DockPanel.Dock="Top" x:Name="HintText" Foreground="#888888" FontSize="11"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button x:Name="ConfirmBtn" Content="Valider" Style="{StaticResource PrimaryButton}"
                    Click="Confirm_Click" Margin="0" />
        </StackPanel>

        <ctrl:MultiSelectComboBox x:Name="LabelsSelect" DockPanel.Dock="Top"
                                  VerticalAlignment="Top" HorizontalAlignment="Stretch" />
    </DockPanel>
</Window>
