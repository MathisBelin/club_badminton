<Window x:Class="BadmintonClub.Views.ResponseDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Réponses" Width="540" Height="600"
        WindowStartupLocation="CenterOwner" Background="#F4F6F4" MinWidth="420" MinHeight="320">
    <DockPanel Margin="18">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" Style="{StaticResource PageTitle}"
                   FontSize="17" Margin="0,0,0,4" />
        <TextBlock x:Name="SubText" DockPanel.Dock="Top" Foreground="#777777" FontSize="12" Margin="0,0,0,12" />

        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="UpdateBtn" Content="💾 Mettre à jour le contact"
                        Style="{StaticResource PrimaryButton}" Click="Update_Click" Padding="14,7"
                        Visibility="Collapsed" ToolTip="Appliquer au contact les informations différentes (en jaune)" />
                <Button Content="Fermer" Click="Close_Click" Padding="16,7" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="List">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E4E9E4" BorderThickness="1" CornerRadius="6"
                                Padding="12,10" Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="White" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDifferent}" Value="True">
                                            <Setter Property="Background" Value="#FFF6D6" />
                                            <Setter Property="BorderBrush" Value="#E6C34A" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding Question}" FontWeight="SemiBold"
                                           Foreground="#233323" TextWrapping="Wrap" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding Answer}" Foreground="#444444" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CurrentText}" Foreground="#B8860B" FontSize="12"
                                           Margin="0,4,0,0" TextWrapping="Wrap"
                                           Visibility="{Binding IsDifferent, Converter={StaticResource BoolToVisibility}}" />
                                <Button Content="✎ Mettre à jour ce champ" Click="UpdateField_Click"
                                        HorizontalAlignment="Left" Padding="9,3" Margin="0,6,0,0" FontSize="12"
                                        ToolTip="Appliquer au contact uniquement cette information"
                                        Visibility="{Binding IsDifferent, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
