<Window x:Class="BadmintonClub.Views.LabelListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="420" MaxHeight="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="22"
                        Background="#EAF2FB" VerticalAlignment="Top">
                    <TextBlock Text="🏷" FontSize="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Width="320">
                    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold" Foreground="#233323"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#888888" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Aucun libellé -->
            <Border x:Name="EmptyBox" Background="#F6F7F9" CornerRadius="8" Padding="14,12" Margin="0,18,0,0"
                    Visibility="Collapsed">
                <TextBlock Text="Cette personne n'est associée à aucun libellé."
                           Foreground="#777777" FontSize="13" TextWrapping="Wrap" />
            </Border>

            <!-- Chips des libellés -->
            <ScrollViewer x:Name="ChipsScroll" VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" MaxHeight="320">
                <ItemsControl x:Name="ChipsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#EAF2FB" BorderBrush="#BBD6EA" BorderThickness="1"
                                    CornerRadius="14" Padding="12,6" Margin="0,0,8,8">
                                <TextBlock Text="{Binding}" Foreground="#1565C0" FontSize="13" FontWeight="SemiBold" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="Fermer" IsCancel="True" IsDefault="True" Padding="16,8"
                        Click="Fermer_Click" Margin="0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
