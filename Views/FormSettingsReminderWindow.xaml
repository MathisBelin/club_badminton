<Window x:Class="BadmintonClub.Views.FormSettingsReminderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="À vérifier dans Google Forms" SizeToContent="Height" Width="640"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F4F6F4">
    <StackPanel Margin="22">

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="⚠" FontSize="22" Foreground="#B8860B" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBlock Text="Réglages à vérifier dans le formulaire" Style="{StaticResource PageTitle}"
                       FontSize="17" VerticalAlignment="Center" TextWrapping="Wrap" />
        </StackPanel>

        <TextBlock TextWrapping="Wrap" Foreground="#444444" Margin="0,0,0,4">
            La collecte des adresses e-mail <Run FontWeight="SemiBold">« Validées »</Run> a été activée
            automatiquement à la création. En revanche, deux options <Run FontWeight="SemiBold">ne peuvent
            pas</Run> être activées par l'application (Google ne les expose pas dans son API).
        </TextBlock>
        <TextBlock TextWrapping="Wrap" Foreground="#444444" Margin="0,0,0,12">
            Ouvrez le formulaire → onglet <Run FontWeight="SemiBold">Paramètres</Run> → section
            <Run FontWeight="SemiBold">Réponses</Run>, et vérifiez que ces réglages sont bien
            <Run FontWeight="SemiBold">activés</Run> :
        </TextBlock>

        <!-- Capture réelle de la section « Paramètres » de Google Forms -->
        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Padding="0" ClipToBounds="True">
            <Image Source="/assets/form_settings_help.png" Stretch="Uniform" />
        </Border>

        <TextBlock Foreground="#B71C1C" FontSize="12" Margin="2,10,0,0" TextWrapping="Wrap"
                   Text="➡ Les deux réglages encadrés en rouge doivent être activés à la main (interrupteurs violets)." />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OpenBtn" Content="🔗 Ouvrir le formulaire" Click="Open_Click" Padding="14,7" />
            <Button Content="J'ai compris" Click="Close_Click" Style="{StaticResource PrimaryButton}"
                    Padding="14,7" Margin="8,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
