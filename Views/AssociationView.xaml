<UserControl x:Class="BadmintonClub.Views.AssociationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Association" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0"
                       Text="Toutes les personnes. Filtrez par libellé(s) ci-dessous." />

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                <TextBlock Text="A au moins un de :" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#555555" FontWeight="SemiBold"
                           ToolTip="Filtre « OU » : personnes ayant au moins un des libellés cochés" />
                <ctrl:MultiSelectComboBox x:Name="LabelSelect" Width="200" VerticalAlignment="Center" />
                <Button x:Name="AdvancedToggle" Content="🔎 Recherche avancée" Click="AdvancedToggle_Click"
                        Margin="10,0,10,0" ToolTip="Filtres avancés par libellés (ET / exclusion)" />
                <Button x:Name="PreinscriptionsBtn" Content="📝 Préinscriptions" Click="Preinscriptions_Click"
                        Margin="0,0,16,0"
                        ToolTip="Voir les préinscriptions et la liste d'attente" />
                <ctrl:SearchBox x:Name="SearchBox" Width="200" TextChanged="SearchBox_TextChanged" />
            </StackPanel>
        </StackPanel>

        <!-- Recherche avancée par libellés -->
        <Border x:Name="AdvancedPanel" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#F4F8FB" BorderBrush="#D6E4F0" BorderThickness="1"
                CornerRadius="6" Padding="14,12" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Recherche avancée par libellés" FontWeight="SemiBold"
                           Foreground="#1565C0" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                    <TextBlock Text="A TOUS ces libellés (ET) :" Width="185" VerticalAlignment="Center"
                               Foreground="#555555" FontWeight="SemiBold" />
                    <ctrl:MultiSelectComboBox x:Name="LabelAll" Width="240" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="N'a AUCUN de ces libellés :" Width="185" VerticalAlignment="Center"
                               Foreground="#555555" FontWeight="SemiBold" />
                    <ctrl:MultiSelectComboBox x:Name="LabelNone" Width="240" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Foreground="#888888" FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"
                           Text="Les personnes affichées ont tous les libellés « ET » et aucun des libellés exclus. Un libellé choisi ici n'est plus proposé dans les autres listes." />
            </StackPanel>
        </Border>

        <!-- Barre d'actions groupées -->
        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#EAF2F8" BorderBrush="#BBD6EA" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#1565C0" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkAssocierButton" Style="{StaticResource PrimaryButton}"
                            Click="BulkAssocier_Click" />
                    <Button x:Name="BulkDissocierButton" Style="{StaticResource DangerButton}"
                            Click="BulkDissocier_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nom" Binding="{Binding Adherent.Nom}" Width="*" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Adherent.Prenom}" Width="*" />
                <DataGridTemplateColumn Header="Téléphone" Width="150"
                                        ClipboardContentBinding="{Binding Adherent.Telephone, Converter={StaticResource PhoneFormat}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Adherent.Telephone, Converter={StaticResource PhoneFormat}}"
                                       Foreground="{Binding Adherent.Telephone, Converter={StaticResource PhoneColor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="E-mail" Width="2*"
                                        ClipboardContentBinding="{Binding Adherent.Email}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                <Hyperlink Click="Email_Click" Foreground="#1565C0"
                                           ToolTip="Écrire un e-mail via Gmail">
                                    <Run Text="{Binding Adherent.Email}" />
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Actions" Width="180" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="👁 Voir" Style="{StaticResource RowButton}"
                                        ToolTip="Voir les libellés de cette personne" Click="Voir_Click" />
                                <Button Content="🏷 Gérer" Style="{StaticResource RowBlueButton}"
                                        ToolTip="Gérer les libellés de cette personne" Click="Gerer_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0" Foreground="#999999" FontSize="13" />
        </Grid>
    </DockPanel>
</UserControl>
