<Window x:Class="BadmintonClub.Views.EmailListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="430" MaxHeight="520" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="22" Background="#EAF2FB" VerticalAlignment="Top">
                    <TextBlock Text="✉" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Width="330">
                    <TextBlock Text="Mails secondaires" FontSize="17" FontWeight="Bold" Foreground="#233323"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#888888" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,18,0,0" MaxHeight="330">
                <ItemsControl x:Name="EmailsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F3F8FE" BorderBrush="#D3E4F5" BorderThickness="1"
                                    CornerRadius="8" Padding="12,9" Margin="0,0,0,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✉" Foreground="#1565C0" FontSize="13" Margin="0,0,10,0"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding}" Foreground="#1B3A5B" FontSize="13.5"
                                               VerticalAlignment="Center" TextWrapping="Wrap" Width="300" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Fermer" IsCancel="True" IsDefault="True" Padding="16,8" Click="Close_Click" Margin="0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
