<Window x:Class="BadmintonClub.Views.AdherentEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BadmintonClub.Controls"
        Title="Adhérent"
        SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Nom *" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="NomBox" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Prénom *" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="PrenomBox" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Téléphone" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="TelephoneBox" />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="E-mail" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="EmailBox" />
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Mails secondaires" Style="{StaticResource FormLabel}" />
            <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SecondaryEmailsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" TextChanged="SecondaryEmail_TextChanged"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1" Content="✕" Click="RemoveEmail_Click"
                                        Margin="6,0,0,0" MinWidth="0" Padding="9,4"
                                        Background="#FDECEA" BorderBrush="#E6A9A0" Foreground="#B71C1C"
                                        ToolTip="Retirer cette adresse" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Button x:Name="AddEmailBtn" Content="＋ Ajouter une adresse" Click="AddEmail_Click"
                    HorizontalAlignment="Left" Margin="0,2,0,0" Padding="10,4" FontSize="12"
                    ToolTip="Renseignez d'abord correctement les adresses en cours" />
        </StackPanel>

        <StackPanel Grid.Row="5" x:Name="LabelsSection" Margin="0,0,0,10" Visibility="Collapsed">
            <TextBlock Text="Associer à des libellés (optionnel)" Style="{StaticResource FormLabel}" />
            <ctrl:MultiSelectComboBox x:Name="LabelsSelect" />
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button Content="Enregistrer" Style="{StaticResource PrimaryButton}"
                    IsDefault="True" Click="Enregistrer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
