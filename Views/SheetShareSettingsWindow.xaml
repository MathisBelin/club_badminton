<Window x:Class="BadmintonClub.Views.SheetShareSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres de partage"
        Height="230" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <CheckBox Grid.Row="0" x:Name="LinkAccessCheck" IsChecked="True" Margin="0,0,0,10"
                  Content="Accessible à toute personne disposant du lien" />

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    IsEnabled="{Binding IsChecked, ElementName=LinkAccessCheck}">
            <TextBlock Text="Les personnes avec le lien sont :" VerticalAlignment="Center"
                       Margin="0,0,8,0" Foreground="#555555" />
            <ComboBox x:Name="RoleCombo" Width="160" SelectedIndex="2">
                <ComboBoxItem Tag="reader">Lecteur</ComboBoxItem>
                <ComboBoxItem Tag="commenter">Commentateur</ComboBoxItem>
                <ComboBoxItem Tag="writer">Éditeur</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button Content="Valider" Style="{StaticResource PrimaryButton}"
                    Click="Valider_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
