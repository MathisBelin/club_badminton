<Window x:Class="BadmintonClub.Views.ContactDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="400" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="22" Background="#EAF2FB" VerticalAlignment="Top">
                    <TextBlock Text="👤" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center" Width="290">
                    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold" Foreground="#233323"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="SubtitleText" FontSize="12" Foreground="#888888" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>

            <Border Background="#F6F8FA" CornerRadius="8" Padding="14,10" Margin="0,18,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Nom" Foreground="#888888" Margin="0,0,16,6" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="NomText" Foreground="#233323"
                               FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Prénom" Foreground="#888888" Margin="0,0,16,6" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PrenomText" Foreground="#233323"
                               FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Téléphone" Foreground="#888888" Margin="0,0,16,6" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TelText" Foreground="#233323"
                               FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="E-mail" Foreground="#888888" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="MailText" Foreground="#1565C0"
                               FontWeight="SemiBold" TextWrapping="Wrap" />
                </Grid>
            </Border>

            <TextBlock Text="Informations telles qu'au moment de l'action." FontSize="10"
                       Foreground="#AAAAAA" Margin="2,8,0,0" TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Fermer" IsCancel="True" IsDefault="True" Padding="16,8"
                        Click="Fermer_Click" Margin="0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
