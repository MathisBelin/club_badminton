<UserControl x:Class="BadmintonClub.Controls.SearchBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="32">
    <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="16" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBlock x:Name="Watermark" Text="Rechercher…" Foreground="#AAAAAA"
                           Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" />
                <TextBox x:Name="Box" BorderThickness="0" Background="Transparent"
                         VerticalContentAlignment="Center" Padding="12,0,0,0"
                         TextChanged="Box_TextChanged" />
            </Grid>

            <Button x:Name="ClearBtn" Grid.Column="1" Content="✕" Visibility="Collapsed"
                    Background="Transparent" BorderThickness="0" MinWidth="0" Padding="8,0"
                    Margin="0" Cursor="Hand" Foreground="#999999" ToolTip="Effacer"
                    Click="Clear_Click" />
        </Grid>
    </Border>
</UserControl>
