<Window x:Class="BadmintonClub.Views.ResponseDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Réponses" Width="560" Height="620"
        WindowStartupLocation="CenterOwner" Background="#F4F6F4" MinWidth="440" MinHeight="340">
    <Window.Resources>
        <!-- Bouton bleu = appliquer la RÉPONSE du formulaire (mettre à jour). -->
        <Style x:Key="UpdateButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1565C0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#0D47A1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Bouton ambre = garder l'état ACTUEL du contact (ignorer). -->
        <Style x:Key="IgnoreButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E0A32E" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#B07E1E" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="18">
        <TextBlock x:Name="HeaderText" DockPanel.Dock="Top" Style="{StaticResource PageTitle}"
                   FontSize="17" Margin="0,0,0,4" />
        <TextBlock x:Name="SubText" DockPanel.Dock="Top" Foreground="#777777" FontSize="12" Margin="0,0,0,12" />

        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="IgnoreAllBtn" Content="✖ Garder l'état actuel" Click="IgnoreAll_Click"
                        Style="{StaticResource IgnoreButton}" Padding="14,7" Margin="0,0,8,0"
                        Visibility="Collapsed"
                        ToolTip="Tout ignorer : le contact garde ses informations actuelles (en ambre)" />
                <Button x:Name="UpdateBtn" Content="💾 Mettre à jour le contact"
                        Style="{StaticResource UpdateButton}" Click="Update_Click" Padding="14,7"
                        Visibility="Collapsed"
                        ToolTip="Appliquer au contact les réponses du formulaire (en bleu)" />
                <Button Content="Fermer" Click="Close_Click" Padding="16,7" Margin="8,0,0,0" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="List">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E4E9E4" BorderThickness="1" CornerRadius="6"
                                Background="White" Padding="12,10" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Question}" FontWeight="SemiBold"
                                           Foreground="#233323" TextWrapping="Wrap" Margin="0,0,0,4" />

                                <!-- Aucune différence : la réponse telle quelle -->
                                <TextBlock Text="{Binding Answer}" Foreground="#444444" TextWrapping="Wrap"
                                           Visibility="{Binding IsDifferent, Converter={StaticResource InverseBoolToVisibility}}" />

                                <!-- Différence : réponse (bleu) vs contact actuel (ambre) + boutons assortis -->
                                <StackPanel Visibility="{Binding IsDifferent, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="#E7F1FB" BorderBrush="#1565C0" BorderThickness="1.4"
                                            CornerRadius="6" Padding="9,6">
                                        <StackPanel>
                                            <TextBlock Text="RÉPONSE DU FORMULAIRE" FontSize="10" FontWeight="Bold"
                                                       Foreground="#1565C0" />
                                            <TextBlock Text="{Binding NewValue}" Foreground="#0D3B66" FontSize="13.5"
                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#FBF1D5" BorderBrush="#C79A28" BorderThickness="1.4"
                                            CornerRadius="6" Padding="9,6" Margin="0,7,0,0">
                                        <StackPanel>
                                            <TextBlock Text="CONTACT ACTUEL" FontSize="10" FontWeight="Bold"
                                                       Foreground="#9A7314" />
                                            <TextBlock Text="{Binding CurrentDisplay}" Foreground="#6B531A" FontSize="13.5"
                                                       TextWrapping="Wrap" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <Button Content="✎ Mettre à jour ce champ" Click="UpdateField_Click"
                                                Style="{StaticResource UpdateButton}" Padding="10,4" FontSize="12"
                                                MinWidth="0"
                                                ToolTip="Remplacer l'info du contact par la réponse du formulaire (encadré bleu)" />
                                        <Button Content="✖ Ignorer" Click="IgnoreField_Click"
                                                Style="{StaticResource IgnoreButton}" Padding="10,4" Margin="7,0,0,0"
                                                FontSize="12" MinWidth="0"
                                                ToolTip="Garder l'info actuelle du contact (encadré ambre) et ne plus signaler cette différence" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
