<Window x:Class="BadmintonClub.Views.AlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="450" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="22" Background="#FEF3D6" VerticalAlignment="Top">
                    <TextBlock Text="⚠" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold" Foreground="#233323"
                           VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap" Width="336" />
            </StackPanel>

            <ItemsControl x:Name="List" Margin="0,16,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFF8E8" BorderBrush="#F0D89A" BorderThickness="1" CornerRadius="7"
                                Padding="10,8" Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="•" Foreground="#C9971F" FontWeight="Bold" Margin="0,0,8,0"
                                           VerticalAlignment="Top" />
                                <TextBlock Text="{Binding}" Foreground="#5C4813" TextWrapping="Wrap" Width="342" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Fermer" IsCancel="True" Padding="16,8" Click="Close_Click" />
                <Button Content="👁 Voir les changements" Click="ViewChanges_Click" Margin="0"
                        Background="#1565C0" Foreground="White" BorderBrush="#0D47A1" FontWeight="SemiBold"
                        Padding="16,8" IsDefault="True"
                        ToolTip="Ouvrir la réponse de la personne (détail des champs)" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
