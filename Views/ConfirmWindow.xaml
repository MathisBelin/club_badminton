<Window x:Class="BadmintonClub.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="420" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Border Background="White" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#55000000" BlurRadius="24" ShadowDepth="4" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border x:Name="IconBadge" Width="44" Height="44" CornerRadius="22"
                        Background="#FDECEA" VerticalAlignment="Top">
                    <TextBlock x:Name="IconText" Text="🗑" FontSize="22"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="TitleText" FontSize="17" FontWeight="Bold" Foreground="#233323"
                           VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap"
                           Width="320" />
            </StackPanel>

            <TextBlock x:Name="MessageText" TextWrapping="Wrap" Margin="0,14,0,0"
                       Foreground="#555555" FontSize="13" LineHeight="20" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="CancelBtn" Content="Annuler" IsCancel="True" Padding="16,8"
                        Click="Cancel_Click" />
                <Button x:Name="ConfirmBtn" Content="Supprimer" Style="{StaticResource DangerButton}"
                        Padding="16,8" IsDefault="True" Click="Confirm_Click" Margin="0" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
