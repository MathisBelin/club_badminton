<Window x:Class="BadmintonClub.Views.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:BadmintonClub.Controls"
        Title="Importer des contacts"
        Height="480" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Libellés cibles -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Libellés cibles (optionnel)" Style="{StaticResource FormLabel}" />
            <ctrl:MultiSelectComboBox x:Name="LabelsSelect" />
            <TextBlock Text="Les contacts importés seront ajoutés à ces libellés."
                       Foreground="#888888" FontSize="11" Margin="0,3,0,0" />
        </StackPanel>

        <!-- Choix du mode -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="ModeFile" Content="Depuis un fichier (Excel / CSV)"
                         IsChecked="True" GroupName="Mode" Margin="0,0,20,0"
                         Checked="Mode_Checked" VerticalContentAlignment="Center" />
            <RadioButton x:Name="ModeText" Content="Coller des e-mails" GroupName="Mode"
                         Checked="Mode_Checked" VerticalContentAlignment="Center" />
        </StackPanel>

        <!-- Zone fichier -->
        <Border x:Name="FilePanel" Grid.Row="3" AllowDrop="True"
                DragOver="DropZone_DragOver" Drop="DropZone_Drop"
                MouseLeftButtonUp="DropZone_Click" Cursor="Hand" VerticalAlignment="Stretch">
            <Grid>
                <Rectangle Stroke="#9CB89C" StrokeDashArray="4 3" StrokeThickness="2"
                           RadiusX="10" RadiusY="10" Fill="#F7FAF7" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="📄" FontSize="34" HorizontalAlignment="Center" />
                    <TextBlock x:Name="DropHint" HorizontalAlignment="Center" Margin="0,8,0,0"
                               Foreground="#555555" TextAlignment="Center"
                               Text="Glissez un fichier Excel/CSV ici,&#x0a;ou cliquez pour parcourir" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Zone texte -->
        <StackPanel x:Name="TextPanel" Grid.Row="3" Visibility="Collapsed">
            <TextBlock Text="Collez les e-mails (séparés par des virgules, espaces ou retours à la ligne) :"
                       Style="{StaticResource FormLabel}" />
            <TextBox x:Name="EmailsBox" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Height="230" Padding="6"
                     VerticalContentAlignment="Top" />
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
            <Button x:Name="ImporterButton" Content="📥 Importer"
                    Style="{StaticResource PrimaryButton}" Click="Importer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
