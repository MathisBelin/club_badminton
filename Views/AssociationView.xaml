<UserControl x:Class="BadmintonClub.Views.AssociationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Association" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0"
                       Text="Choisissez un libellé pour voir ses membres." />

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                <TextBlock Text="Libellé :" VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#555555" FontWeight="SemiBold" />
                <ctrl:MultiSelectComboBox x:Name="LabelSelect" SingleSelect="True" Width="240" VerticalAlignment="Center" />
                <Button Content="👥 Associer" Style="{StaticResource PrimaryButton}"
                        Margin="10,0,10,0" Click="Associer_Click"
                        ToolTip="Associer des contacts à un libellé" />
                <Button Content="⏳ Personnes en attente" Click="Pending_Click" Margin="0,0,16,0"
                        ToolTip="Voir les personnes ayant renseigné des infos mais pas d'e-mail" />
                <ctrl:SearchBox x:Name="SearchBox" Width="220" TextChanged="SearchBox_TextChanged" />
            </StackPanel>
        </StackPanel>

        <!-- Barre d'actions groupées -->
        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#B71C1C" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkDissocierButton" Style="{StaticResource DangerButton}"
                            Click="BulkDissocier_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid>
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nom" Binding="{Binding Adherent.Nom}" Width="*" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Adherent.Prenom}" Width="*" />
                <DataGridTemplateColumn Header="Téléphone" Width="150"
                                        ClipboardContentBinding="{Binding Adherent.Telephone, Converter={StaticResource PhoneFormat}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding Adherent.Telephone, Converter={StaticResource PhoneFormat}}"
                                       Foreground="{Binding Adherent.Telephone, Converter={StaticResource PhoneColor}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="E-mail" Width="2*"
                                        ClipboardContentBinding="{Binding Adherent.Email}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" TextTrimming="CharacterEllipsis">
                                <Hyperlink Click="Email_Click" Foreground="#1565C0"
                                           ToolTip="Écrire un e-mail via Gmail">
                                    <Run Text="{Binding Adherent.Email}" />
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Action" Width="130" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✂ Dissocier" Style="{StaticResource RowDeleteButton}"
                                    ToolTip="Retirer ce contact du libellé" Click="Dissocier_Click" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="EmptyResults" Visibility="Collapsed" IsHitTestVisible="False"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,40,0,0" Foreground="#999999" FontSize="13" />
        </Grid>
    </DockPanel>
</UserControl>
