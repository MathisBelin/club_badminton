<Window x:Class="BadmintonClub.Views.CreateSheetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Créer un Google Sheet"
        Height="440" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Nom du classeur" Style="{StaticResource FormLabel}" />
            <TextBox x:Name="SheetNameBox" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Type de création" Style="{StaticResource FormLabel}" />
            <RadioButton x:Name="RadioBlank" Content="Classeur vierge" IsChecked="True"
                         GroupName="Type" Margin="0,4,0,0" Checked="Type_Checked" />
            <RadioButton x:Name="RadioModel" Content="À partir d'un modèle (Excel / CSV)"
                         GroupName="Type" Margin="0,6,0,0" Checked="Type_Checked" />
        </StackPanel>

        <!-- Zone modèle (visible seulement en mode « modèle ») -->
        <Border x:Name="TemplateZone" Grid.Row="2" AllowDrop="True" Visibility="Collapsed"
                DragOver="Drop_DragOver" Drop="Drop_Drop" MouseLeftButtonUp="Drop_Click"
                Cursor="Hand" Margin="0,4,0,0">
            <Grid>
                <Rectangle x:Name="DropRect" Stroke="#9CB89C" StrokeDashArray="4 3" StrokeThickness="2"
                           RadiusX="10" RadiusY="10" Fill="#F7FAF7" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="DropIcon" Text="📄" FontSize="30" HorizontalAlignment="Center" />
                    <TextBlock x:Name="TemplateHint" HorizontalAlignment="Center" Margin="0,8,0,0"
                               Foreground="#555555" TextAlignment="Center"
                               Text="Glissez un modèle Excel/CSV ici,&#x0a;ou cliquez pour choisir dans vos modèles." />
                    <Button x:Name="ClearTemplateButton" Content="Retirer le modèle" Margin="0,8,0,0"
                            HorizontalAlignment="Center" Visibility="Collapsed" Click="ClearTemplate_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Button Content="⚙ Paramètres de partage" HorizontalAlignment="Left"
                    Click="Partage_Click" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Annuler" IsCancel="True" Click="Annuler_Click" />
                <Button Content="✅ Créer" Style="{StaticResource PrimaryButton}"
                        Click="Creer_Click" Margin="0" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
