<UserControl x:Class="BadmintonClub.Views.ContactsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:BadmintonClub.Controls">
    <DockPanel Margin="24">

        <!-- En-tête -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Contacts" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="CountText" Foreground="#777777" FontSize="12" Margin="0,2,0,0" />

            <!-- Barre d'outils -->
            <DockPanel Margin="0,12,0,0">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="📥 Importer" Click="Importer_Click"
                            ToolTip="Importer des contacts (fichier Excel/CSV ou liste d'e-mails)" />
                    <Button Content="👥 Associer" Click="Associer_Click" />
                    <ToggleButton x:Name="AdvancedToggle" Content="🔍 Recherche avancée"
                                  Checked="Advanced_Toggled" Unchecked="Advanced_Toggled"
                                  Padding="14,7" Margin="0,0,8,0" Cursor="Hand" />
                    <Button Content="📊 Exporter CSV" Style="{StaticResource ExcelButton}"
                            Click="Exporter_Click"
                            ToolTip="Exporter les contacts en CSV (tous, ou la sélection)" />
                    <Button Content="➕ Ajouter" Style="{StaticResource PrimaryButton}"
                            Click="Ajouter_Click" Margin="0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔎" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="14" />
                    <TextBox x:Name="SearchBox" Width="240"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Rechercher par nom, prénom, téléphone ou e-mail" />
                </StackPanel>
            </DockPanel>

            <!-- Recherche avancée -->
            <Border x:Name="AdvancedPanel" Visibility="Collapsed" Margin="0,10,0,0"
                    Background="White" BorderBrush="#DDDDDD" BorderThickness="1"
                    CornerRadius="6" Padding="12">
                <StackPanel>
                    <TextBlock Text="Filtrer par libellé" Style="{StaticResource FormLabel}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ctrl:MultiSelectComboBox x:Name="LabelFilter" Grid.Column="0" />
                        <Button Grid.Column="1" Content="Réinitialiser" Margin="8,0,0,0"
                                Click="ResetFilter_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Barre d'actions groupées (animée) -->
        <Border x:Name="BulkBar" DockPanel.Dock="Top" Visibility="Collapsed"
                Background="#FDECEA" BorderBrush="#F5C6C0" BorderThickness="1"
                CornerRadius="6" Padding="12,8" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BulkCountText" Grid.Column="0" VerticalAlignment="Center"
                           Foreground="#B71C1C" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Annuler la sélection" Click="ClearSelection_Click" />
                    <Button x:Name="BulkDeleteButton" Style="{StaticResource DangerButton}"
                            Click="BulkDelete_Click" Margin="0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tableau -->
        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTemplateColumn Width="42" CanUserResize="False">
                    <DataGridTemplateColumn.Header>
                        <CheckBox x:Name="SelectAllBox" Click="SelectAll_Click"
                                  HorizontalAlignment="Center" ToolTip="Tout sélectionner" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="150" />
                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="2*" />
                <DataGridTemplateColumn Header="Actions" Width="150" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource RowButton}" Content="✏"
                                        ToolTip="Modifier" Click="Modifier_Click" />
                                <Button Style="{StaticResource RowButton}" Content="🗑"
                                        ToolTip="Supprimer" Click="Supprimer_Click" />
                                <Button Style="{StaticResource RowButton}" Content="⋮"
                                        FontWeight="Bold" ToolTip="Gérer les libellés" Click="PlusOptions_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
