<Window x:Class="BadmintonClub.Views.ManageTemplatesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gérer les modèles de mail"
        Height="440" Width="640"
        WindowStartupLocation="CenterOwner"
        MinHeight="320" MinWidth="520"
        ShowInTaskbar="False">
    <DockPanel Margin="18">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Modèles de mail" Style="{StaticResource PageTitle}" VerticalAlignment="Center" />
            <Button Content="➕ Ajouter un modèle" Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right" Click="Ajouter_Click" />
        </Grid>

        <Button DockPanel.Dock="Bottom" Content="Fermer" IsCancel="True" HorizontalAlignment="Right"
                Margin="0,12,0,0" Click="Fermer_Click" />

        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Single"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Objet" Binding="{Binding Subject}" Width="1.6*" />
                <DataGridTemplateColumn Header="Actions" Width="230" CanUserResize="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource RowModifyButton}" Content="✏ Modifier"
                                        Click="Modifier_Click" />
                                <Button Style="{StaticResource RowDeleteButton}" Content="🗑 Supprimer"
                                        Click="Supprimer_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
