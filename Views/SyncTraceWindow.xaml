<Window x:Class="BadmintonClub.Views.SyncTraceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trace de la synchronisation"
        Height="460" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderText" Style="{StaticResource FormLabel}"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" x:Name="HintText" Foreground="#777777" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,10" />

        <!-- Légende jaune -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <Border Width="14" Height="14" Background="#FFF3CD" BorderBrush="#E0C36A"
                    BorderThickness="1" CornerRadius="2" VerticalAlignment="Center" />
            <TextBlock Text="Associée grâce à l'option « personnes connues » (sans e-mail dans le Sheet)"
                       VerticalAlignment="Center" Margin="8,0,0,0" Foreground="#8A6D0B" FontSize="12" />
        </StackPanel>

        <DataGrid Grid.Row="3" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ViaKnown}" Value="True">
                            <Setter Property="Background" Value="#FFF3CD" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120" />
                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Fermer" IsCancel="True" Click="Fermer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
