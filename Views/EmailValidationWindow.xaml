<Window x:Class="BadmintonClub.Views.EmailValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Vérification des e-mails"
        Height="480" Width="680"
        WindowStartupLocation="CenterOwner"
        MinHeight="360" MinWidth="560"
        ShowInTaskbar="False">
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" TextWrapping="Wrap" Margin="0,0,0,12" Foreground="#555555"
                   Text="Certaines adresses semblent incorrectes. Corrigez-les ci-dessous (une proposition est déjà appliquée), puis validez — ou annulez l'import. Les adresses encore invalides ne seront pas importées." />

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="SummaryText" VerticalAlignment="Center"
                       Foreground="#777777" FontSize="12" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Annuler l'import" IsCancel="True" Click="Annuler_Click" />
                <Button Content="✅ Valider" Style="{StaticResource PrimaryButton}"
                        Click="Valider_Click" Margin="0" />
            </StackPanel>
        </Grid>

        <DataGrid x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Contact" Binding="{Binding ContactLabel}" Width="*" />
                <DataGridTextColumn Header="E-mail saisi" Binding="{Binding Original}" Width="1.6*" />
                <DataGridTemplateColumn Header="Correction proposée" Width="1.6*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Corrected, UpdateSourceTrigger=PropertyChanged}"
                                     BorderThickness="1" Margin="2" Padding="4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Statut" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                                       Margin="4,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#C62828" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                <Setter Property="Foreground" Value="#2E7D32" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
