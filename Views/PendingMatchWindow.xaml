<Window x:Class="BadmintonClub.Views.PendingMatchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Correspondances"
        Height="420" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PersonText" Style="{StaticResource FormLabel}"
                   TextWrapping="Wrap" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" x:Name="HintText" Foreground="#777777" FontSize="12"
                   TextWrapping="Wrap" Margin="0,0,0,12" />

        <DataGrid Grid.Row="2" x:Name="Grid" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" SelectionMode="Extended"
                  SelectionUnit="Cell" ClipboardCopyMode="ExcludeHeader">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="140" />
                <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Fermer" IsCancel="True" Click="Fermer_Click" Margin="0" />
        </StackPanel>
    </Grid>
</Window>
